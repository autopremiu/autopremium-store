<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Auto Premium Service</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

<!-- TOP BAR -->
<div class="topbar">
  <div class="container">
    <span><i class="fas fa-phone"></i> +57 300 5965252</span>
    <span><i class="fas fa-envelope"></i> </span>
    <span><i class="fas fa-truck"></i> Envíos a todo Colombia</span>
  </div>
</div>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      <div class="logo-text">
        <span class="logo-auto">AUTO</span>
        <span class="logo-premium">PREMIUM</span>
        <span class="logo-service">service</span>
      </div>
    </a>

    <div class="nav-search">
      <form action="/productos" method="GET" class="search-form">
        <input type="text" name="q" placeholder="Buscar repuestos, marcas, modelos..." autocomplete="off" id="searchInput">
        <button type="submit"><i class="fas fa-search"></i></button>
      </form>
      <div class="search-suggestions" id="searchSuggestions"></div>
    </div>

    <div class="nav-actions">
      <% if (user) { %>
        <div class="nav-user dropdown">
          <button class="btn-icon"><i class="fas fa-user"></i> <span class="hide-mobile"><%= user.full_name.split(' ')[0] %></span></button>
          <div class="dropdown-menu">
            <a href="/account"><i class="fas fa-tachometer-alt"></i> Mi Cuenta</a>
            <a href="/account/pedidos"><i class="fas fa-box"></i> Mis Pedidos</a>
            <% if (user.role === 'admin') { %><a href="/admin"><i class="fas fa-cog"></i> Administración</a><% } %>
            <div class="dropdown-divider"></div>
            <form action="/auth/logout" method="POST" style="display:inline">
              <button type="submit" class="dropdown-item-btn"><i class="fas fa-sign-out-alt"></i> Cerrar Sesión</button>
            </form>
          </div>
        </div>
      <% } else { %>
        <a href="/auth/login" class="btn-icon"><i class="fas fa-user"></i> <span class="hide-mobile">Ingresar</span></a>
      <% } %>

      <a href="/cart" class="btn-icon cart-btn">
        <i class="fas fa-shopping-cart"></i>
        <span class="cart-count" id="cartCount"><%= cart.count || 0 %></span>
      </a>
    </div>

    <button class="nav-toggle" id="navToggle"><i class="fas fa-bars"></i></button>
  </div>

  <div class="nav-categories" id="navMenu">
    <div class="container">
      <a href="/productos" class="<%= !filters || !filters.marca ? 'active' : '' %>">Todas las Marcas</a>
      <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
        <% brands.forEach(brand => { %>
          <a href="/productos?marca=<%= brand.slug %>" class="<%= filters && filters.marca === brand.slug ? 'active' : '' %>"><%= brand.name %></a>
        <% }) %>
      <% } %>
    </div>
  </div>
</nav>

<main class="main-content">
