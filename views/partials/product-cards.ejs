<% products.forEach(product => { %>
<div class="product-card">
  <a href="/producto/<%= product.slug %>" class="product-link">
    <div class="product-img-wrap">
      <% if (product.thumbnail) { %>
        <img src="<%= product.thumbnail %>" alt="<%= product.name %>" loading="lazy">
      <% } else { %>
        <div class="product-img-placeholder"><i class="fas fa-cog"></i></div>
      <% } %>
      <% if (product.compare_price && product.compare_price > product.price) { %>
        <span class="badge-discount">-<%= Math.round((1 - product.price/product.compare_price)*100) %>%</span>
      <% } %>
      <% if (product.is_featured) { %><span class="badge-featured">Destacado</span><% } %>
    </div>
    <div class="product-info">
      <div class="product-brand"><%= product.brands?.name || product.brand?.name || '' %></div>
      <h3 class="product-name"><%= product.name %></h3>
      <div class="product-rating">
        <% for(let i=1;i<=5;i++) { %><i class="fas fa-star <%= i <= Math.round(product.rating || 0) ? 'active' : '' %>"></i><% } %>
        <span>(<%= product.review_count || 0 %>)</span>
      </div>
      <div class="product-price">
        <span class="price-current">$<%= Number(product.price).toLocaleString('es-CO') %></span>
        <% if (product.compare_price && product.compare_price > product.price) { %>
          <span class="price-old">$<%= Number(product.compare_price).toLocaleString('es-CO') %></span>
        <% } %>
      </div>
    </div>
  </a>
  <div class="product-actions">
    <button class="btn btn-primary btn-add-cart" data-id="<%= product.id %>" data-name="<%= product.name %>">
      <i class="fas fa-cart-plus"></i> Agregar
    </button>
    <button class="btn btn-icon-sm btn-wishlist" data-id="<%= product.id %>" title="Agregar a favoritos">
      <i class="far fa-heart"></i>
    </button>
  </div>
</div>
<% }) %>

<script>
// Marcar corazones de productos que ya están en wishlist
(async function() {
  try {
    const res = await fetch('/api/wishlist');
    if (!res.ok) return; // no autenticado, no hacer nada
    const data = await res.json();
    if (!data.success) return;
    data.items.forEach(id => {
      document.querySelectorAll(`.btn-wishlist[data-id="${id}"] i`).forEach(icon => {
        icon.classList.replace('far', 'fas');
        icon.closest('.btn-wishlist').classList.add('active');
      });
    });
  } catch(e) {}
})();

// Toggle wishlist al hacer click
document.querySelectorAll('.btn-wishlist').forEach(btn => {
  btn.addEventListener('click', async function(e) {
    e.preventDefault();
    const product_id = this.dataset.id;
    const icon = this.querySelector('i');

    try {
      const res = await fetch('/api/wishlist/toggle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ product_id })
      });

      if (res.status === 401) {
        window.location.href = '/auth/login';
        return;
      }

      const data = await res.json();
      if (data.success) {
        if (data.action === 'added') {
          icon.classList.replace('far', 'fas');
          this.classList.add('active');
        } else {
          icon.classList.replace('fas', 'far');
          this.classList.remove('active');
        }
      }
    } catch(e) {}
  });
});
</script>
