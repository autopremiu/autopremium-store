<%- include('../partials/header') %>
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="admin-brand"><i class="fas fa-cog"></i><span>Administración</span></div>
    <nav class="admin-nav">
      <a href="/admin"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
      <a href="/admin/productos"><i class="fas fa-box"></i> Productos</a>
      <a href="/admin/pedidos" class="active"><i class="fas fa-shopping-bag"></i> Pedidos</a>
      <a href="/admin/categorias"><i class="fas fa-tags"></i> Categorías</a>
      <a href="/admin/usuarios"><i class="fas fa-users"></i> Usuarios</a>
      <div class="admin-nav-divider"></div>
      <a href="/"><i class="fas fa-store"></i> Ver Tienda</a>
    </nav>
  </aside>
  <div class="admin-main">
    <div class="admin-header">
      <h1>Pedido <%= order.order_number %></h1>
      <a href="/admin/pedidos" class="btn btn-outline">← Volver</a>
    </div>
    <div class="admin-grid-2">
      <div class="admin-card">
        <h3>Actualizar Estado</h3>
        <form action="/admin/pedidos/<%= order.id %>/estado" method="POST">
          <div class="form-group">
            <label>Estado</label>
            <select name="status">
              <% ['pending','confirmed','processing','shipped','delivered','cancelled'].forEach(s => { %>
              <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Número de seguimiento</label>
            <input type="text" name="tracking_number" value="<%= order.tracking_number || '' %>">
          </div>
          <button type="submit" class="btn btn-primary">Actualizar</button>
        </form>
      </div>
      <div class="admin-card">
        <h3>Info del Cliente</h3>
        <p><strong>Nombre:</strong> <%= order.users?.full_name %></p>
        <p><strong>Email:</strong> <%= order.users?.email %></p>
        <p><strong>Teléfono:</strong> <%= order.users?.phone || '—' %></p>
        <h4 style="margin-top:1rem">Dirección de envío</h4>
        <p><%= order.shipping_address?.address_line1 %><br><%= order.shipping_address?.city %>, <%= order.shipping_address?.state %></p>
      </div>
    </div>
    <div class="admin-card">
      <h3>Artículos del Pedido</h3>
      <table class="admin-table">
        <thead><tr><th>Producto</th><th>SKU</th><th>Cant.</th><th>Precio Unit.</th><th>Total</th></tr></thead>
        <tbody>
          <% order.order_items.forEach(item => { %>
          <tr>
            <td><%= item.product_name %></td>
            <td><%= item.product_sku || '—' %></td>
            <td><%= item.quantity %></td>
            <td>$<%= Number(item.unit_price).toLocaleString('es-CO') %></td>
            <td>$<%= Number(item.total_price).toLocaleString('es-CO') %></td>
          </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr><td colspan="4"><strong>Total</strong></td><td><strong>$<%= Number(order.total).toLocaleString('es-CO') %></strong></td></tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
