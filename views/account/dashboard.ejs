<%- include('../partials/header') %>
<div class="container" style="padding-top:2rem;padding-bottom:3rem">
  <div class="account-layout">
    <aside class="account-sidebar">
      <div class="account-user">
        <div class="avatar-circle"><%= user.full_name.charAt(0).toUpperCase() %></div>
        <div><strong><%= user.full_name %></strong><span><%= user.email %></span></div>
      </div>
      <nav class="account-nav">
        <a href="/account"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
        <a href="/account/pedidos"><i class="fas fa-box"></i> Mis Pedidos</a>
        <a href="/account/perfil"><i class="fas fa-user"></i> Mi Perfil</a>
        <a href="/account/direcciones"><i class="fas fa-map-marker-alt"></i> Direcciones</a>
      </nav>
    </aside>
    <div class="account-main">
      <h2>Mi Cuenta</h2>
      <p>Bienvenido de vuelta, <strong><%= user.full_name.split(' ')[0] %></strong></p>
      <h3 style="margin-top:2rem">Últimos Pedidos</h3>
      <% if (orders.length > 0) { %>
      <table class="admin-table">
        <thead><tr><th>#</th><th>Fecha</th><th>Total</th><th>Estado</th><th></th></tr></thead>
        <tbody>
          <% orders.forEach(o => { %>
          <tr>
            <td><%= o.order_number %></td>
            <td><%= new Date(o.created_at).toLocaleDateString('es-CO') %></td>
            <td>$<%= Number(o.total).toLocaleString('es-CO') %></td>
            <td><span class="badge-status status-<%= o.status %>"><%= o.status %></span></td>
            <td><a href="/account/pedidos/<%= o.order_number %>" class="btn btn-sm btn-outline">Ver</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <div class="empty-state"><i class="fas fa-box-open"></i><p>No tienes pedidos aún</p><a href="/productos" class="btn btn-primary">Explorar Catálogo</a></div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
