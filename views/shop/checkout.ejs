<%- include('../partials/header') %>

<div class="container" style="padding-top:2rem;padding-bottom:3rem">
  <h1 class="page-title">Finalizar Compra</h1>

  <div class="checkout-layout">
    <!-- LEFT -->
    <div class="checkout-form">

      <!-- SHIPPING -->
      <div class="checkout-section">
        <h3><span class="step-num">1</span> Dirección de Envío</h3>

        <% if (addresses.length > 0) { %>
        <div class="saved-addresses">
          <% addresses.forEach(addr => { %>
            <label class="addr-option">
              <input type="radio" name="saved_address"
                value='<%= JSON.stringify(addr) %>'
                onchange="fillAddress(this.value)">
              <div>
                <strong><%= addr.full_name %></strong>
                <span><%= addr.address_line1 %>, <%= addr.city %>, <%= addr.state %></span>
              </div>
            </label>
          <% }) %>

          <label class="addr-option">
            <input type="radio" name="saved_address" value="new" checked onchange="fillAddress('new')">
            <div><strong>Nueva dirección</strong></div>
          </label>
        </div>
        <% } %>

        <div id="addressForm">
          <div class="form-row">
            <div class="form-group">
              <label>Nombre completo *</label>
              <input type="text" id="addrName" value="<%= user.full_name %>" required>
            </div>
            <div class="form-group">
              <label>Teléfono *</label>
              <input type="text" id="addrPhone" required>
            </div>
          </div>

          <div class="form-group">
            <label>Dirección *</label>
            <input type="text" id="addrLine1" required>
          </div>

          <div class="form-group">
            <label>Apartamento / Torre</label>
            <input type="text" id="addrLine2">
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>Ciudad *</label>
              <input type="text" id="addrCity" required>
            </div>
            <div class="form-group">
              <label>Departamento *</label>
              <input type="text" id="addrState" required>
            </div>
            <div class="form-group">
              <label>Código Postal</label>
              <input type="text" id="addrPostal">
            </div>
          </div>
        </div>
      </div>

      <!-- PAYMENT -->
      <div class="checkout-section">
        <h3><span class="step-num">2</span> Método de Pago</h3>

        <div class="payment-methods">
          <label class="pay-option active">
            <input type="radio" checked>
            💳 PayU (PSE, Tarjeta, Nequi)
          </label>
        </div>
      </div>

      <div class="form-group">
        <label>Notas del pedido</label>
        <textarea id="orderNotes" rows="3"></textarea>
      </div>

      <button id="placeOrderBtn" class="btn btn-primary btn-lg" style="width:100%">
        🔒 Confirmar Pedido — $<%= Number(cart.total).toLocaleString('es-CO') %>
      </button>

      <p class="secure-msg">
        <i class="fas fa-shield-alt"></i> Pago seguro con PayU
      </p>

    </div>

    <!-- RIGHT -->
    <div class="order-summary">
      <h3>Tu Pedido (<%= cart.count %>)</h3>

      <% cart.items.forEach(item => { %>
        <div class="order-item">
          <div class="order-item-info">
            <span><%= item.name %></span>
          </div>
          <div class="order-item-price">
            $<%= Number(item.price * item.quantity).toLocaleString('es-CO') %>
          </div>
        </div>
      <% }) %>

      <div class="summary-lines">
        <div class="summary-line total">
          <span>Total</span>
          <span>$<%= Number(cart.total).toLocaleString('es-CO') %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function fillAddress(val) {
  if (val === 'new') return;
  const a = JSON.parse(val);
  addrName.value = a.full_name || '';
  addrPhone.value = a.phone || '';
  addrLine1.value = a.address_line1 || '';
  addrLine2.value = a.address_line2 || '';
  addrCity.value = a.city || '';
  addrState.value = a.state || '';
  addrPostal.value = a.postal_code || '';
}

document.getElementById('placeOrderBtn').addEventListener('click', async () => {
  const btn = placeOrderBtn;
  btn.disabled = true;
  btn.innerHTML = 'Redirigiendo a PayU...';

  const res = await fetch('/checkout/payu', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({
      shipping_address: {
        full_name: addrName.value,
        phone: addrPhone.value,
        address_line1: addrLine1.value,
        address_line2: addrLine2.value,
        city: addrCity.value,
        state: addrState.value,
        postal_code: addrPostal.value,
        country: 'Colombia'
      },
      notes: orderNotes.value
    })
  });

  const data = await res.json();
  document.body.innerHTML = data.form;
  document.forms[0].submit();
});
</script>

<%- include('../partials/footer') %>