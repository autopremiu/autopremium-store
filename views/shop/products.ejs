<%- include('../partials/header') %>

<!-- OVERLAY — va ANTES del layout, fuera de todo contenedor -->
<div class="filter-overlay" id="filterOverlay" onclick="closeFilters()"></div>

<div class="container" style="padding-top:2rem; padding-bottom:3rem">

  <!-- BREADCRUMB -->
  <div class="breadcrumb">
    <a href="/">Inicio</a> <i class="fas fa-chevron-right"></i>
    <span><%= filters.q ? `Resultados: "${filters.q}"` : 'Catálogo' %></span>
  </div>

  <div class="catalog-layout">

    <!-- SIDEBAR / DRAWER DE FILTROS -->
    <aside class="filters-sidebar" id="filterSidebar">

      <!-- Header del drawer (sticky en mobile, oculto en desktop via CSS) -->
      <div class="filter-drawer-header">
        <h3><i class="fas fa-sliders-h" style="color:var(--red);margin-right:0.5rem"></i>Filtros</h3>
        <button class="filter-drawer-close" onclick="closeFilters()" aria-label="Cerrar filtros">
          <i class="fas fa-times"></i>
        </button>
      </div>

      <div style="padding:0 1.25rem 1.5rem">
        <div class="filter-header">
          <h3>Filtros</h3>
          <a href="/productos" class="filter-clear">Limpiar todo</a>
        </div>

        <form action="/productos" method="GET" id="filterForm">
          <% if (filters.q) { %><input type="hidden" name="q" value="<%= filters.q %>"><% } %>

          

          <div class="filter-group">
            <h4>Marcas</h4>
            <label class="filter-check">
              <input type="radio" name="marca" value="" <%= !filters.marca ? 'checked' : '' %> onchange="this.form.submit()">
              <span>Todas</span>
            </label>
            <% brands.slice(0,8).forEach(brand => { %>
            <label class="filter-check">
              <input type="radio" name="marca" value="<%= brand.slug %>" <%= filters.marca === brand.slug ? 'checked' : '' %> onchange="this.form.submit()">
              <span><%= brand.name %></span>
            </label>
            <% }) %>
          </div>

          <div class="filter-group">
            <h4>Precio</h4>
            <div class="price-range">
              <input type="number" name="min" placeholder="Mínimo" value="<%= filters.min || '' %>">
              <span style="color:var(--text-muted)">—</span>
              <input type="number" name="max" placeholder="Máximo" value="<%= filters.max || '' %>">
            </div>
            <button type="submit" class="btn btn-outline btn-sm" style="width:100%;margin-top:0.75rem;justify-content:center">
              <i class="fas fa-check"></i> Aplicar precio
            </button>
          </div>
        </form>
      </div>
    </aside>

    <!-- ÁREA DE PRODUCTOS -->
    <div class="catalog-main">

      

      <div class="catalog-toolbar">
        <div class="results-count"><%= total %> productos encontrados</div>
        <select class="sort-select" onchange="window.location.href='/productos?'+new URLSearchParams({...Object.fromEntries(new URLSearchParams(location.search)),...{orden:this.value}})">
          <option value="">Más recientes</option>
          <option value="precio-asc"  <%= filters.orden === 'precio-asc'  ? 'selected' : '' %>>Precio: Menor a Mayor</option>
          <option value="precio-desc" <%= filters.orden === 'precio-desc' ? 'selected' : '' %>>Precio: Mayor a Menor</option>
          <option value="nombre"      <%= filters.orden === 'nombre'      ? 'selected' : '' %>>Nombre A-Z</option>
        </select>
      </div>

      <% if (products.length > 0) { %>
      <div class="products-grid">
        <%- include('../partials/product-cards', { products }) %>
      </div>
      <% } else { %>
      <div class="empty-state">
        <i class="fas fa-search"></i>
        <h3>No encontramos productos</h3>
        <p>Intenta con otros filtros o términos de búsqueda</p>
        <a href="/productos" class="btn btn-primary">Ver todo el catálogo</a>
      </div>
      <% } %>

      <!-- PAGINACIÓN -->
      <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page > 1) { %>
          <a href="?page=<%= page-1 %>" class="page-btn"><i class="fas fa-chevron-left"></i></a>
        <% } %>
        <% for(let i = 1; i <= totalPages; i++) { %>
          <a href="?page=<%= i %>" class="page-btn <%= i === page ? 'active' : '' %>"><%= i %></a>
        <% } %>
        <% if (page < totalPages) { %>
          <a href="?page=<%= page+1 %>" class="page-btn"><i class="fas fa-chevron-right"></i></a>
        <% } %>
      </div>
      <% } %>

    </div><!-- /catalog-main -->
  </div><!-- /catalog-layout -->
</div><!-- /container -->

<script>
/* ── FILTER DRAWER ── */
function openFilters() {
  document.getElementById('filterSidebar').classList.add('drawer-open');
  document.getElementById('filterOverlay').classList.add('active');
  document.body.style.overflow = 'hidden';
}

function closeFilters() {
  document.getElementById('filterSidebar').classList.remove('drawer-open');
  document.getElementById('filterOverlay').classList.remove('active');
  document.body.style.overflow = '';
}

/* Mostrar botón trigger solo en mobile */
(function handleResize() {
  const trigger = document.getElementById('filterTrigger');
  if (!trigger) return;
  trigger.style.display = window.innerWidth <= 768 ? 'flex' : 'none';
  window.addEventListener('resize', () => {
    trigger.style.display = window.innerWidth <= 768 ? 'flex' : 'none';
    if (window.innerWidth > 768) closeFilters();
  });
})();

/* Swipe izquierda para cerrar el drawer */
const sidebar = document.getElementById('filterSidebar');
let touchStartX = 0;
sidebar.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
sidebar.addEventListener('touchend',   e => { if (touchStartX - e.changedTouches[0].clientX > 60) closeFilters(); });

/* Cerrar con ESC */
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeFilters(); });
</script>

<%- include('../partials/footer') %>
