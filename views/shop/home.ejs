<%- include('../partials/header') %>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">⚡ Envío rápido a todo Colombia</div>
    <h1>Repuestos Automotrices<br><span>de Alta Calidad</span></h1>
    <p>Más de 10,000 referencias disponibles. Marcas originales y alternativas para todos los vehículos.</p>
    <div class="hero-actions">
      <a href="/productos" class="btn btn-primary btn-lg">Ver Catálogo <i class="fas fa-arrow-right"></i></a>
      <a href="#categorias" class="btn btn-outline btn-lg">Explorar Categorías</a>
    </div>
    <div class="hero-stats">
      <div><strong>10K+</strong><span>Referencias</span></div>
      <div><strong>50+</strong><span>Marcas</span></div>
      <div><strong>24h</strong><span>Envío Express</span></div>
    </div>
  </div>
  <div class="hero-visual">
    <div class="hero-glow"></div>
    <div class="hero-rings">
      <div class="ring ring-1"></div>
      <div class="ring ring-2"></div>
      <div class="ring ring-3"></div>
    </div>
    <div class="hero-icon-main"><i class="fas fa-cog fa-spin-slow"></i></div>
  </div>
</section>

<!-- FEATURES BAR -->
<section class="features-bar">
  <div class="container features-grid">
    <div class="feature-item">
      <i class="fas fa-shipping-fast"></i>
      <div><strong>Envío Gratis</strong><p>En pedidos +$150.000</p></div>
    </div>
    <div class="feature-item">
      <i class="fas fa-shield-alt"></i>
      <div><strong>Garantía</strong><p>En todos los productos</p></div>
    </div>
    <div class="feature-item">
      <i class="fas fa-undo"></i>
      <div><strong>Devoluciones</strong><p>30 días sin preguntas</p></div>
    </div>
    <div class="feature-item">
      <i class="fas fa-headset"></i>
      <div><strong>Soporte 24/7</strong><p>Asesoría técnica</p></div>
    </div>
  </div>
</section>

<!-- CATEGORIES -->
<section class="section" id="categorias">
  <div class="container">
    <div class="section-header">
      <h2>Categorías</h2>
      <a href="/productos" class="link-all">Ver todo <i class="fas fa-arrow-right"></i></a>
    </div>
    <div class="categories-grid">
      <% categories.forEach(cat => { %>
      <a href="/productos?categoria=<%= cat.slug %>" class="category-card">
        <div class="cat-icon"><%= cat.icon || '🔧' %></div>
        <div class="cat-name"><%= cat.name %></div>
      </a>
      <% }) %>
      <% if (categories.length === 0) { %>
        <% ['Motor y Transmisión','Frenos y Suspensión','Eléctrico','Carrocería','Filtros','Iluminación','Escape','Interior'].forEach((c,i) => { %>
        <a href="/productos" class="category-card">
          <div class="cat-icon"><%= ['⚙️','🔧','⚡','🚗','🛢️','💡','💨','❄️'][i] %></div>
          <div class="cat-name"><%= c %></div>
        </a>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<!-- FEATURED PRODUCTS -->
<section class="section section-dark">
  <div class="container">
    <div class="section-header">
      <h2>Productos Destacados</h2>
      <a href="/productos?featured=true" class="link-all">Ver más <i class="fas fa-arrow-right"></i></a>
    </div>
    <% if (featured.length > 0) { %>
    <div class="products-grid">
      <%- include('../partials/product-cards', { products: featured }) %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <i class="fas fa-box-open"></i>
      <p>Próximamente más productos disponibles</p>
      <a href="/admin/productos/nuevo" class="btn btn-primary">Agregar Productos</a>
    </div>
    <% } %>
  </div>
</section>

<!-- BRANDS -->
<% if (brands.length > 0) { %>
<section class="section brands-section">
  <div class="container">
    <h2 class="text-center">Marcas que Manejamos</h2>
    <div class="brands-slider">
      <% brands.forEach(brand => { %>
      <div class="brand-item"><%= brand.name %></div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- CTA BANNER -->
<section class="cta-banner">
  <div class="container">
    <div class="cta-content">
      <h2>¿Necesitas asesoría técnica?</h2>
      <p>Nuestros expertos te ayudan a encontrar el repuesto correcto para tu vehículo</p>
      <a href="https://wa.me/573000000000" class="btn btn-whatsapp btn-lg" target="_blank">
        <i class="fab fa-whatsapp"></i> Chatear por WhatsApp
      </a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
