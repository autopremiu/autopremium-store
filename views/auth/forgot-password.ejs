<%- include('../partials/header') %>

<div class="container" style="padding-top:3rem;padding-bottom:3rem;max-width:480px;margin:0 auto">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-icon"><i class="fas fa-lock"></i></div>
      <h1>Recuperar Contraseña</h1>
      <p>Ingresa tu email y te enviaremos un enlace para restablecer tu contraseña.</p>
    </div>

    <% if (success) { %>
    <div class="alert alert-success">
      <i class="fas fa-check-circle"></i> <%= success %>
    </div>
    <% } %>

    <% if (error) { %>
    <div class="alert alert-error">
      <i class="fas fa-exclamation-circle"></i> <%= error %>
    </div>
    <% } %>

    <% if (!success) { %>
    <form action="/auth/recuperar" method="POST">
      <div class="form-group">
        <label>Correo electrónico</label>
        <input type="email" name="email" placeholder="tucorreo@ejemplo.com" required autofocus>
      </div>
      <button type="submit" class="btn btn-primary btn-lg" style="width:100%">
        <i class="fas fa-paper-plane"></i> Enviar enlace
      </button>
    </form>
    <% } %>

    <div class="auth-footer" style="margin-top:1.5rem;text-align:center">
      <a href="/auth/login"><i class="fas fa-arrow-left"></i> Volver al inicio de sesión</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>