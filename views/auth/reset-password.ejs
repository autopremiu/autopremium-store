<%- include('../partials/header') %>

<div class="container" style="padding-top:3rem;padding-bottom:3rem;max-width:480px;margin:0 auto">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-icon"><i class="fas fa-key"></i></div>
      <h1>Nueva Contraseña</h1>
      <p>Ingresa tu nueva contraseña.</p>
    </div>

    <% if (success) { %>
    <div class="alert alert-success">
      <i class="fas fa-check-circle"></i> <%= success %>
    </div>
    <div style="text-align:center;margin-top:1.5rem">
      <a href="/auth/login" class="btn btn-primary btn-lg">Iniciar Sesión</a>
    </div>

    <% } else if (error && !token) { %>
    <div class="alert alert-error">
      <i class="fas fa-exclamation-circle"></i> <%= error %>
    </div>
    <div style="text-align:center;margin-top:1.5rem">
      <a href="/auth/recuperar" class="btn btn-primary">Solicitar nuevo enlace</a>
    </div>

    <% } else { %>
    <% if (error) { %>
    <div class="alert alert-error">
      <i class="fas fa-exclamation-circle"></i> <%= error %>
    </div>
    <% } %>

    <form action="/auth/reset/<%= token %>" method="POST">
      <div class="form-group">
        <label>Nueva contraseña</label>
        <input type="password" name="password" placeholder="Mínimo 6 caracteres" minlength="6" required autofocus>
      </div>
      <div class="form-group">
        <label>Confirmar contraseña</label>
        <input type="password" name="confirm_password" placeholder="Repite tu contraseña" required>
      </div>
      <button type="submit" class="btn btn-primary btn-lg" style="width:100%">
        <i class="fas fa-save"></i> Guardar contraseña
      </button>
    </form>
    <% } %>

    <div class="auth-footer" style="margin-top:1.5rem;text-align:center">
      <a href="/auth/login"><i class="fas fa-arrow-left"></i> Volver al inicio de sesión</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>